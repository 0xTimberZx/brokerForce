# Leave VITE_API_URL unset for local dev -- src/api/client.ts defaults to
# "/api", which goes through the Vite dev proxy (vite.config.ts) to
# apps/api with no CORS setup needed, since the browser only ever talks to
# the Vite dev server itself.
#
# Only set this if pointing at a real deployed API instead of the local dev
# proxy -- apps/api has no CORS middleware installed, so a direct
# cross-origin URL here will fail in the browser unless that's added too.
# VITE_API_URL=https://your-deployed-api.example.com
